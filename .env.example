# ============================================================
# .env.example — Copia este archivo como .env y completa los valores
# NUNCA subas .env a git. Agrega .env a tu .gitignore
# ============================================================

# --- Base de datos ---
MYSQL_DATABASE=moodle
MYSQL_USER=moodle_user
MYSQL_PASSWORD=          # Genera con: openssl rand -base64 32
MYSQL_ROOT_PASSWORD=     # Genera con: openssl rand -base64 32

# --- URL pública de Moodle (con https://) ---
SERVICE_URL_NGINX=https://tu-dominio.com

# --- Administrador de Moodle ---
MOODLE_ADMIN_USER=admin
MOODLE_ADMIN_PASS=       # Mínimo 8 caracteres, mayúsculas, números y símbolos
MOODLE_ADMIN_EMAIL=      # Email real del administrador
